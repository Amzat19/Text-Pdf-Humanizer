# Copy this file to .env and paste ONE key. The app auto-detects which provider
# you configured. All three below are FREE tiers - no credit card, personal
# account, 2-minute signup. Without any key the app runs in MOCK mode
# (simulated rewrites - the text mostly comes back unchanged).

# --- Option 1 (recommended): Groq -------------------------------------------
# Signup: https://console.groq.com  -> API Keys -> Create
# Free tier: ~1,000 requests/day on llama-3.3-70b-versatile (open-weights, great rewriter)
GROQ_API_KEY=

# --- Option 2: Google AI Studio (Gemini) -------------------------------------
# Signup: https://aistudio.google.com -> Get API key
# Free tier: ~1,500 requests/day on Gemini Flash
# GEMINI_API_KEY=

# --- Option 3: Cerebras ------------------------------------------------------
# Signup: https://cloud.cerebras.ai -> API Keys
# Free tier: ~1M tokens/day, extremely fast
# CEREBRAS_API_KEY=

# --- Any OpenAI-compatible endpoint (e.g. local Ollama on a bigger machine) --
# LLM_BASE_URL=http://localhost:11434/v1/chat/completions
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2

# --- OpenRouter (paid, supported but not required) ---------------------------
# OPENROUTER_API_KEY=

# If you set multiple keys, force one: groq | gemini | cerebras | custom | openrouter
# LLM_PROVIDER=groq

# PORT=3777
# MOCK_LLM=1   # force mock mode even with a key present

# Set this when deploying publicly (Netlify env vars) - the UI will ask for it
# once and remember. Unset = no gate (fine for local use).
# APP_PASSWORD=pick-something-long

